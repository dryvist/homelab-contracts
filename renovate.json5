{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":timezone(America/Indiana/Indianapolis)",
  ],
  // Schema-only repo — only GitHub Actions and JSON Schema $ref deps actually exist
  enabledManagers: ["github-actions"],
  prHourlyLimit: 4,
  prConcurrentLimit: 10,
  schedule: ["before 6am on monday"],
  packageRules: [
    {
      // Pin trusted-org actions to major version (per JacobPEvans/.github policy)
      matchManagers: ["github-actions"],
      matchPackagePatterns: ["^googleapis/", "^actions/", "^github/"],
      pinDigests: false,
      extractVersion: "^v(?<version>\\d+)",
    },
    {
      // SHA-pin everything else
      matchManagers: ["github-actions"],
      excludePackagePatterns: ["^googleapis/", "^actions/", "^github/"],
      pinDigests: true,
    },
  ],
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["security"],
  },
}
